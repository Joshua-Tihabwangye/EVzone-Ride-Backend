                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"rider@evzone.local\",\n  \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b=pm.response.json(); pm.collectionVariables.set('riderToken', b.data.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "login",
