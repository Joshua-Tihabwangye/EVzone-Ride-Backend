{
  "name": "evzone-ride-backend",
  "version": "10.0.0",
  "description": "Production-ready unified EVzone Ride & Logistics backend with universal dispatch-unit matching across Rider, Driver, Fleet Partner, Agent/Dispatcher, Admin, CorporatePay integration and every mobility/logistics service.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings=0",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "monitoring:alerts:validate": "node scripts/validate-alerts.mjs",
    "monitoring:alertmanager:validate": "node scripts/validate-alertmanager.mjs",
    "monitoring:validate": "npm run monitoring:alerts:validate && npm run monitoring:alertmanager:validate",
    "contract:check": "node scripts/check-openapi-contract.mjs",
    "openapi:export": "node scripts/export-openapi.mjs",
    "openapi:diff": "node scripts/diff-openapi.mjs",
    "security:secrets": "node scripts/secret-scan.mjs",
    "typeorm": "typeorm-ts-node-commonjs",
    "db:schema:drop": "npm run typeorm -- schema:drop -d src/database/data-source.ts",
    "db:migration:generate": "npm run typeorm -- migration:generate src/database/migrations/AutoMigration -d src/database/data-source.ts",
    "db:migration:run": "npm run typeorm -- migration:run -d src/database/data-source.ts",
    "db:migration:revert": "npm run typeorm -- migration:revert -d src/database/data-source.ts",
    "db:migration:run:prod": "node dist/database/data-source.js migration:run",
    "smoke": "node scripts/smoke-test.mjs",
    "smoke:platform": "node scripts/platform-smoke-test.mjs",
    "smoke:hardening": "node scripts/hardening-smoke-test.mjs",
    "smoke:report-upgrade": "node scripts/report-upgrade-smoke-test.mjs",
    "smoke:report": "node scripts/report-upgrades-smoke-test.mjs",
    "smoke:fleet": "node scripts/fleet-partner-smoke-test.mjs",
    "smoke:agent": "node scripts/agent-portal-smoke-test.mjs",
    "smoke:admin": "node scripts/admin-portal-smoke-test.mjs",
    "smoke:corporatepay": "node scripts/corporatepay-partner-smoke-test.mjs",
    "smoke:corporatepay:school": "node scripts/corporatepay-school-shuttle-smoke-test.mjs",
    "smoke:dispatch": "node scripts/universal-dispatch-smoke-test.mjs",
    "smoke:cors": "node scripts/smoke-cors.mjs",
    "smoke:month2:audit": "node scripts/month2-audit-smoke-test.mjs",
    "smoke:month2:financial": "node scripts/month2-financial-smoke-test.mjs",
    "smoke:month2:dispatch": "node scripts/month2-dispatch-smoke-test.mjs",
    "smoke:month2:tenant": "node scripts/month2-tenant-smoke-test.mjs",
    "smoke:health": "node scripts/smoke-health.mjs",
    "smoke:logging": "node scripts/smoke-logging.mjs",
    "smoke:document-lifecycle": "node scripts/smoke-document-lifecycle.mjs",
    "smoke:ride-to-offer": "node scripts/smoke-ride-to-offer.mjs",
    "smoke:payment-webhook-to-ledger": "node scripts/smoke-payment-webhook-to-ledger.mjs",
    "smoke:suite": "node scripts/smoke-suite.mjs",
    "test:dispatch": "jest --runInBand src/universal-dispatch"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/event-emitter": "3.1.0",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/platform-socket.io": "11.1.27",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "11.0.2",
    "@nestjs/websockets": "11.1.27",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-express": "^0.67.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-ioredis": "^0.67.0",
    "@opentelemetry/instrumentation-kafkajs": "^0.28.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.65.0",
    "@opentelemetry/instrumentation-pg": "^0.71.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@socket.io/redis-adapter": "8.3.0",
    "bcryptjs": "3.0.3",
    "bullmq": "^5.79.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cloudinary": "2.10.0",
    "compression": "1.8.1",
    "dotenv": "17.2.3",
    "firebase-admin": "^13.7.0",
    "helmet": "8.2.0",
    "ioredis": "5.10.1",
    "joi": "^18.2.3",
    "js-yaml": "^5.2.0",
    "kafkajs": "2.2.4",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "6.9.16",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.22.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "sql.js": "1.14.1",
    "typeorm": "0.3.30",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.39.2",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.27",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "2.0.0",
    "@types/node": "24.10.13",
    "@types/nodemailer": "6.4.17",
    "@types/passport-jwt": "4.0.1",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "6.0.3",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "globals": "17.0.0",
    "jest": "30.2.0",
    "prettier": "3.7.4",
    "source-map-support": "0.5.21",
    "sql.js": "1.14.1",
    "supertest": "7.2.2",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.1"
  },
  "engines": {
    "node": ">=20"
  }
}
