    {
      "name": "Authentication",
      "item": [
        {
          "name": "Agent login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/agent/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "agent",
                "auth",
                "login"
              ]
            },
            "description": "EVzone Agent Portal v7 endpoint.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"agent@evzone.local\",\n  \"password\": \"Password123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login succeeded', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "const json = pm.response.json();",
                  "const token = json.accessToken || json.data?.accessToken || json.tokens?.accessToken;",
                  "const refresh = json.refreshToken || json.data?.refreshToken || json.tokens?.refreshToken;",
                  "if (token) pm.collectionVariables.set('agentAccessToken', token);",
                  "if (refresh) pm.collectionVariables.set('agentRefreshToken', refresh);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
