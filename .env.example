NODE_ENV=development
HOST=0.0.0.0
PORT=3000
CORS_ORIGINS=*

# Zero-dependency local database. Docker Compose overrides this with PostgreSQL.
DB_TYPE=postgres
DATABASE_URL=postgresql://evzone:evzone-group@localhost:5432/evzone
SQLITE_PATH=./data/evzone.sqlite
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true
DB_LOGGING=false
SEED_DEMO=false

JWT_SECRET=evzone-local-access-secret-2026
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

STORAGE_PATH=./storage
MATCH_RADIUS_KM=25
OFFER_TTL_SECONDS=120
MAX_DAILY_DRIVING_MINUTES=600
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_REQUESTS=240

# CorporatePay integration. Sandbox is fully operational without external credentials.
CORPORATEPAY_MODE=sandbox
CORPORATEPAY_MOCK_AUTO_APPROVE=true
CORPORATEPAY_BASE_URL=
CORPORATEPAY_API_KEY=
CORPORATEPAY_WEBHOOK_SECRET=evzone-corporatepay-local-secret
CORPORATEPAY_SIGNING_SECRET=evzone-local-signing-secret

# CorporatePay server-to-server partner API (v9).
CORPORATEPAY_PARTNER_CLIENT_ID=corporatepay
CORPORATEPAY_PARTNER_SHARED_SECRET=evzone-corporatepay-local-shared-secret
CORPORATEPAY_PARTNER_API_KEY=evzone-corporatepay-local-key
CORPORATEPAY_PARTNER_ALLOW_API_KEY_ONLY=true
CORPORATEPAY_PARTNER_MAX_SKEW_SECONDS=300
CORPORATEPAY_QUOTE_TTL_MINUTES=15
CORPORATEPAY_EVENTS_URL=
CORPORATEPAY_ESG_BASELINE_KG_PER_KM=0.192
CORPORATEPAY_ESG_EV_KG_PER_KM=0.053
CORPORATEPAY_ESG_HYBRID_KG_PER_KM=0.115
CORPORATEPAY_ESG_ICE_KG_PER_KM=0.192

# School App fleet synchronization and encrypted integration credentials.
SCHOOL_WEBHOOK_SECRET=evzone-school-local-secret
INTEGRATION_ENCRYPTION_KEY=evzone-local-integration-encryption-key-change-in-production
API_PUBLIC_URL=http://localhost:3000

# Production-hardening additions (v3).
IDEMPOTENCY_TTL_SECONDS=86400
GEO_LOOKUP_BASE_URL=https://nominatim.openstreetmap.org
ROUTE_LOOKUP_BASE_URL=https://router.project-osrm.org
GEO_REQUEST_TIMEOUT_MS=5000
REDIS_URL=
REDIS_SOCKET_ADAPTER_ENABLED=false
REDIS_CONNECT_TIMEOUT_MS=3000
REDIS_SOCKET_REQUEST_TIMEOUT_MS=5000
OPERATIONS_WATCHDOG_ENABLED=true
OPERATIONS_WATCHDOG_INTERVAL_MS=30000
DRIVER_HEARTBEAT_TIMEOUT_MS=300000
TRIP_REQUEST_TIMEOUT_MS=600000
ACTIVE_SERVICE_STUCK_THRESHOLD_MS=1800000
CASHOUT_AUTO_APPROVE=false
CASHOUT_PAYOUT_PROVIDER=LOCAL

# Report-driven production infrastructure additions (v4).
# Redis is optional locally; when configured it backs sessions, OTPs, locks, geo indexes and Socket.IO.
REDIS_DISABLED=false
DRIVER_GEO_TTL_SECONDS=300
SOCKET_CORS_ORIGINS=*

# Durable driver/job matching.
MATCH_INITIAL_RADIUS_M=3000
MATCH_MAX_RADIUS_M=40000
MATCH_RADIUS_STEP_M=3000
MATCH_CONCURRENT_OFFERS=5
MATCH_OFFER_TTL_SECONDS=30
MATCH_JOB_TTL_SECONDS=900
MATCH_RETRY_INTERVAL_SECONDS=10
DELIVERY_MATCH_CONCURRENT_OFFERS=5
DELIVERY_MATCH_MAX_RADIUS_M=40000

# PostgreSQL/PostGIS bootstrap and safe local compliance defaults.
POSTGIS_AUTO_SETUP=true
STRICT_DRIVER_COMPLIANCE=false
DELIVERY_DROPOFF_OTP_REQUIRED=true
ROUTE_AVG_SPEED_KPH=30

# Durable domain-event outbox. Add KAFKA_BROKERS to enable Kafka publishing.
KAFKA_DISABLED=true
KAFKA_BROKERS=
KAFKA_CLIENT_ID=evzone-ride
KAFKA_TOPIC_PREFIX=evzone
KAFKA_SSL=false
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_CONNECTION_TIMEOUT_MS=5000
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_RECONNECT_INTERVAL_MS=30000
DOMAIN_EVENT_FLUSH_INTERVAL_MS=10000

# File storage: local is immediately usable; Cloudinary activates when all credentials are set.
CLOUDINARY_DISABLED=true
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=evzone-ride
PUBLIC_BASE_URL=http://localhost:3000
MAX_FILE_SIZE_BYTES=15728640
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,video/mp4
FILE_SCAN_PROVIDER=NONE

# Push notifications: LOCAL retains in-app/WebSocket delivery. FCM, EXPO and WEBHOOK are optional.
PUSH_PROVIDER=LOCAL
FIREBASE_SERVICE_ACCOUNT_JSON=
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
PUSH_WEBHOOK_URL=
PUSH_TIMEOUT_MS=5000

# Payment-provider factory. MOCK works immediately; Flutterwave activates with credentials.
PAYMENT_PROVIDER=MOCK
MOCK_PAYMENT_AUTO_APPROVE=true
FLUTTERWAVE_BASE_URL=https://developersandbox-api.flutterwave.com
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_REQUEST_TIMEOUT_MS=10000

# Password-recovery and legacy compatibility controls.
OTP_MAX_ATTEMPTS=5
PASSWORD_RESET_TTL_MINUTES=15
LEGACY_API_SUNSET=2027-06-30

# Mobile app contract and regional defaults (v5).
MIN_ANDROID_APP_VERSION=1.0.0
MIN_IOS_APP_VERSION=1.0.0
MIN_WEB_APP_VERSION=1.0.0
DEFAULT_COUNTRY_CODE=UG
DEFAULT_CURRENCY=UGX
DEFAULT_TIMEZONE=Africa/Kampala
SUPPORT_PHONE=
SUPPORT_EMAIL=
MAP_PROVIDER=CONFIGURABLE

# Fleet Partner web OIDC federation (v6).
# Local email/password JWTs continue to work alongside external OIDC access tokens.
OIDC_AUTHORITY=https://accounts.evzone.app
OIDC_ISSUER=https://accounts.evzone.app
OIDC_AUDIENCE=
OIDC_JWKS_URI=
OIDC_JWKS_CACHE_SECONDS=3600
JWT_CLOCK_TOLERANCE_SECONDS=30
